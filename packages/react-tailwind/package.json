{
  "name": "@m3/react-tailwind",
  "version": "0.0.0",
  "description": "M3 components implemented with tailwind-variants over the shared @m3/core factories. Ships the Tailwind v4 @theme preset.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./button": {
      "types": "./src/button.ts",
      "default": "./src/button.ts"
    },
    "./icon-button": {
      "types": "./src/icon-button.ts",
      "default": "./src/icon-button.ts"
    },
    "./switch": {
      "types": "./src/switch.ts",
      "default": "./src/switch.ts"
    },
    "./checkbox": {
      "types": "./src/checkbox.ts",
      "default": "./src/checkbox.ts"
    },
    "./radio": {
      "types": "./src/radio.ts",
      "default": "./src/radio.ts"
    },
    "./chip": {
      "types": "./src/chip.ts",
      "default": "./src/chip.ts"
    },
    "./tooltip": {
      "types": "./src/tooltip.ts",
      "default": "./src/tooltip.ts"
    },
    "./dialog": {
      "types": "./src/dialog.ts",
      "default": "./src/dialog.ts"
    },
    "./menu": {
      "types": "./src/menu.ts",
      "default": "./src/menu.ts"
    },
    "./tabs": {
      "types": "./src/tabs.ts",
      "default": "./src/tabs.ts"
    },
    "./slider": {
      "types": "./src/slider.ts",
      "default": "./src/slider.ts"
    },
    "./select": {
      "types": "./src/select.ts",
      "default": "./src/select.ts"
    },
    "./preset.css": "./styles/preset.css",
    "./tokens.css": "./node_modules/@m3/tokens/styles/tokens.css",
    "./theme.css": "./node_modules/@m3/tokens/styles/theme.css"
  },
  "files": ["src", "styles"],
  "scripts": {
    "build": "echo \"@m3/react-tailwind: utilities generated by the host app's Tailwind v4 build\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@m3/core": "workspace:*",
    "@m3/tokens": "workspace:*",
    "tailwind-variants": "^0.3.0"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.6.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  }
}

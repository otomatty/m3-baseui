{
  "name": "@m3/react-vanilla-extract",
  "version": "0.0.0",
  "description": "M3 components implemented with vanilla-extract recipes over the shared @m3/core factories.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./button": {
      "types": "./src/button.ts",
      "default": "./src/button.ts"
    },
    "./icon-button": {
      "types": "./src/icon-button.ts",
      "default": "./src/icon-button.ts"
    },
    "./switch": {
      "types": "./src/switch.ts",
      "default": "./src/switch.ts"
    },
    "./checkbox": {
      "types": "./src/checkbox.ts",
      "default": "./src/checkbox.ts"
    },
    "./radio": {
      "types": "./src/radio.ts",
      "default": "./src/radio.ts"
    },
    "./chip": {
      "types": "./src/chip.ts",
      "default": "./src/chip.ts"
    },
    "./tooltip": {
      "types": "./src/tooltip.ts",
      "default": "./src/tooltip.ts"
    },
    "./dialog": {
      "types": "./src/dialog.ts",
      "default": "./src/dialog.ts"
    },
    "./menu": {
      "types": "./src/menu.ts",
      "default": "./src/menu.ts"
    },
    "./tabs": {
      "types": "./src/tabs.ts",
      "default": "./src/tabs.ts"
    },
    "./slider": {
      "types": "./src/slider.ts",
      "default": "./src/slider.ts"
    },
    "./select": {
      "types": "./src/select.ts",
      "default": "./src/select.ts"
    },
    "./textfield": {
      "types": "./src/textfield.ts",
      "default": "./src/textfield.ts"
    },
    "./navigation-bar": {
      "types": "./src/navigation-bar.ts",
      "default": "./src/navigation-bar.ts"
    },
    "./fab": {
      "types": "./src/fab.ts",
      "default": "./src/fab.ts"
    },
    "./divider": {
      "types": "./src/divider.ts",
      "default": "./src/divider.ts"
    },
    "./progress": {
      "types": "./src/progress.ts",
      "default": "./src/progress.ts"
    },
    "./list": {
      "types": "./src/list.ts",
      "default": "./src/list.ts"
    },
    "./snackbar": {
      "types": "./src/snackbar.ts",
      "default": "./src/snackbar.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "echo \"@m3/react-vanilla-extract: compiled by the host app's VE plugin\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@m3/core": "workspace:*",
    "@m3/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.6.0",
    "@vanilla-extract/css": "^1.15.0",
    "@vanilla-extract/recipes": "^0.5.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}

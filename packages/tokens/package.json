{
  "name": "@m3-baseui/tokens",
  "version": "1.0.1",
  "description": "Single source-of-truth M3 design tokens and generators (CSS vars / vanilla-extract contract / Tailwind v4 @theme).",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otomatty/m3-baseui.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://github.com/otomatty/m3-baseui#readme",
  "bugs": {
    "url": "https://github.com/otomatty/m3-baseui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "@m3/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contract.css": {
      "types": "./src/generated/contract.css.ts",
      "default": "./src/generated/contract.css.ts"
    },
    "./tokens.css": "./styles/tokens.css",
    "./theme.css": "./styles/theme.css"
  },
  "files": [
    "dist",
    "styles",
    "src/generated"
  ],
  "scripts": {
    "gen": "bun run src/build.ts",
    "build": "bun run gen && tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@material/material-color-utilities": "^0.3.0"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.15.0"
  },
  "peerDependenciesMeta": {
    "@vanilla-extract/css": {
      "optional": true
    }
  },
  "sideEffects": [
    "**/*.css"
  ]
}

{
  "name": "m3-baseui",
  "version": "0.0.0",
  "private": true,
  "description": "Material Design 3 component library built on Base UI — vanilla-extract / Tailwind CSS v4 dual support.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "gen:tokens": "bun run --filter @m3/tokens build",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "clean": "rm -rf packages/*/dist packages/*/*.tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "bun-types": "^1.3.14",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT"
}

{
  "name": "@m3-baseui/core",
  "version": "1.1.0",
  "description": "Engine-neutral M3 logic: ThemeProvider, dynamic color, Ripple, state layer, and headless component factories.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otomatty/m3-baseui.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/otomatty/m3-baseui#readme",
  "bugs": {
    "url": "https://github.com/otomatty/m3-baseui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "@m3/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@m3-baseui/tokens": "workspace:*",
